{
	"name": "njs-nest-pdfconsultor-backend",
	"version": "0.1.0",
	"description": "Servicio NestJS para consulta de cartolas PDF.",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"packageManager": "yarn@1.22.22",
	"engines": {
		"node": "25.8.0"
	},
	"scripts": {
		"prebuild": "rimraf dist",
		"build": "nest build",
		"format": "prettier --write .",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"test": "vitest run",
		"test:ci": "vitest run --reporter=default --reporter=json --outputFile=./artifacts/test/vitest.json",
		"test:watch": "vitest",
		"test:run": "vitest run",
		"coverage": "vitest run --coverage",
		"coverage:ci": "vitest run --coverage --reporter=default --reporter=json --outputFile=./artifacts/coverage/vitest-coverage.json",
		"test:e2e": "jest --config ./test/jest-e2e.config.ts --runInBand",
		"test:e2e:ci": "jest --config ./test/jest-e2e.config.ts --runInBand --json --outputFile=./artifacts/test/jest-e2e.json",
		"test:e2e:watch": "jest --config ./test/jest-e2e.config.ts --watch",
		"seed:ci": "ts-node --transpile-only -r tsconfig-paths/register ./src/ci/verify-seed.ts",
		"start:ci": "ts-node --transpile-only -r tsconfig-paths/register ./src/ci/start-ci-server.ts",
		"openapi:export": "ts-node --transpile-only -r tsconfig-paths/register ./src/ci/export-openapi.ts",
		"perf:ci": "k6 run ./test/performance/validate.js",
		"prepare": "husky",
		"commit:cz": "cz"
	},
	"dependencies": {
		"@google-cloud/logging-winston": "^6.0.1",
		"@nestjs/common": "^11.1.16",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.1.16",
		"@nestjs/mapped-types": "^2.1.0",
		"@nestjs/platform-express": "^11.1.16",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/terminus": "^11.1.1",
		"@nestjs/typeorm": "^11.0.0",
		"@validatecl/rut": "^4.0.7",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"joi": "^18.1.2",
		"nest-winston": "^1.10.2",
		"pdf-to-base64": "^1.0.3",
		"pg": "^8.20.0",
		"pg-mem": "^3.0.14",
		"reflect-metadata": "^0.2.2",
		"rimraf": "^6.1.3",
		"rxjs": "^7.8.2",
		"typeorm": "^0.3.28",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.3.0",
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/testing": "^11.1.16",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.3.5",
		"@types/supertest": "^7.2.0",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"@vitest/coverage-istanbul": "^4.0.18",
		"cz-conventional-changelog": "3.3.0",
		"eslint": "^10.0.3",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jest": "^30.2.0",
		"lint-staged": "^16.3.2",
		"prettier": "^3.8.1",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml}": [
			"prettier --write"
		]
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
